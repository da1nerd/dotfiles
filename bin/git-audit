#!/usr/bin/env bash
#
# git-audit — report git repositories under [path] that have unsynced work.
#
# Usage:
#   git-audit [--fetch] [-v|--verbose] [-h|--help] [path]
#
# Default path: ~/git. Exit 0 if clean, 1 if any repos flagged, 2 on usage errors.

set -u
set -o pipefail
# Note: set -e is intentionally off. Per-repo git failures are expected and
# are handled with explicit status checks.

usage() {
  cat <<'EOF'
Usage: git-audit [--fetch] [-v|--verbose] [-h|--help] [path]

Report git repositories under [path] that are not safely synced:
uncommitted, staged, untracked, unpushed, no-upstream, no-remote, or env-files.
All local branches are checked for unpushed/no-upstream status.

  --fetch        Fetch from all remotes before auditing (parallelized, 8 at a time).
  -v, --verbose  Multi-line per-repo detail instead of compact tags.
  -h, --help     Show this help and exit.

Path defaults to ~/git. Exit 0 if no repos are flagged, 1 if any are,
2 on a usage error.
EOF
}

# --- CLI parsing ---

fetch=0
verbose=0
path=""

while (( $# > 0 )); do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --fetch) fetch=1 ;;
    -v|--verbose) verbose=1 ;;
    --)
      shift
      if (( $# > 0 )); then
        if [[ -n "$path" ]]; then
          echo "git-audit: unexpected argument: $1" >&2; exit 2
        fi
        path="$1"; shift
      fi
      if (( $# > 0 )); then
        echo "git-audit: unexpected argument: $1" >&2; exit 2
      fi
      ;;
    -*)
      echo "git-audit: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -n "$path" ]]; then
        echo "git-audit: unexpected argument: $1" >&2; exit 2
      fi
      path="$1"
      ;;
  esac
  shift || true
done

path="${path:-$HOME/git}"

if [[ ! -d "$path" ]]; then
  echo "git-audit: not a directory: $path" >&2
  exit 2
fi

path_abs=$(cd "$path" && pwd)

# --- Color setup ---
#
# Red tags when stdout is a terminal, plain when piped/redirected.

if [[ -t 1 ]]; then
  CLR_TAG=$'\033[31m'
  CLR_RESET=$'\033[0m'
else
  CLR_TAG=""
  CLR_RESET=""
fi

# --- Discovery ---
#
# Walk "$path_abs" and collect every directory containing a ".git" entry
# (either a directory or a gitfile for worktrees). Stop descending once a
# repo is found, so submodules / vendored checkouts aren't audited
# separately.

repos=()
unreadable=()
find_errs=$(mktemp)
while IFS= read -r -d '' repo; do
  repos+=("$repo")
done < <(find "$path_abs" -type d \
  \( -exec sh -c 'test -e "$0/.git"' {} \; -print0 -prune \) 2>"$find_errs")

# Parse permission-denied lines. GNU and BSD find both format these as
# `find: 'path': Permission denied` or `find: path: Permission denied`.
while IFS= read -r line; do
  [[ "$line" == *"Permission denied"* ]] || continue
  p="${line#find: }"
  p="${p%: Permission denied}"
  p="${p#\'}"
  p="${p%\'}"
  unreadable+=("$p")
done < "$find_errs"
rm -f "$find_errs"

# --- Optional fetch pass ---
#
# When --fetch is passed, run `git fetch --quiet --all` on every discovered
# repo before running checks. Parallelized via xargs -P 8. Fetch failures
# (e.g. unreachable remote) are tolerated — they don't abort the audit.

if (( fetch && ${#repos[@]} > 0 )); then
  printf '%s\0' "${repos[@]}" \
    | xargs -0 -n 1 -P 8 -I {} sh -c 'git -C "$1" fetch --quiet --all 2>/dev/null || true' _ {}
fi

# --- Per-repo checks ---
#
# For each repo, compute tags. A repo with no tags is silently skipped.
# The ordering of tags on output follows the order they're appended here.

any_flagged=0
any_no_upstream=0

# Truncate a comma-joined list to the first 5 entries, append "(+N more)".
truncate_list() {
  local -a items=("$@")
  local n=${#items[@]}
  local result=""
  local limit=$(( n <= 5 ? n : 5 ))
  local i
  for (( i = 0; i < limit; i++ )); do
    [[ -n "$result" ]] && result+=", "
    result+="${items[$i]}"
  done
  if (( n > 5 )); then
    result+=" (+$(( n - 5 )) more)"
  fi
  echo "$result"
}

for repo in "${repos[@]+"${repos[@]}"}"; do
  tags=()
  detail_modified=()
  detail_untracked=()
  detail_staged=()
  no_upstream_branches=()
  unpushed_info=()
  env_files=()
  default_remote=""

  # Probe with a cheap command. If this fails the repo is broken.
  if ! probe_err=$(git -C "$repo" rev-parse --git-dir 2>&1 >/dev/null); then
    tags+=("error: $(echo "$probe_err" | head -1)")
    any_flagged=1
    rel="${repo#$path_abs/}"
    [[ "$rel" == "$repo" ]] && rel="."
    if (( verbose )); then
      printf '%s\n  Error: %s\n' "$rel" "$(echo "$probe_err" | head -1)"
    else
      printf '%s [%s%s%s]\n' "$rel" "$CLR_TAG" "${tags[0]}" "$CLR_RESET"
    fi
    continue
  fi

  porc=$(git -C "$repo" status --porcelain 2>/dev/null)

  # Parse porcelain lines once into per-category detail.
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    idx="${line:0:1}"
    wt="${line:1:1}"
    rest="${line:3}"
    case "$idx$wt" in
      '??') detail_untracked+=("$rest") ;;
      *)
        if [[ "$wt" =~ [MDARCU] ]]; then
          detail_modified+=("$rest")
        fi
        if [[ "$idx" =~ [MADRCU] && "$wt" == " " ]]; then
          detail_staged+=("$rest")
        fi
        ;;
    esac
  done <<< "$porc"

  (( ${#detail_modified[@]} > 0 )) && tags+=("uncommitted")
  (( ${#detail_staged[@]} > 0 )) && tags+=("staged")
  (( ${#detail_untracked[@]} > 0 )) && tags+=("untracked")

  remotes=$(git -C "$repo" remote 2>/dev/null)

  if [[ -z "$remotes" ]]; then
    tags+=("no-remote")
  else
    if grep -q '^origin$' <<< "$remotes"; then
      default_remote="origin"
    else
      default_remote=$(head -1 <<< "$remotes")
    fi

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      upstream=$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name \
                   "${branch}@{u}" 2>/dev/null || true)
      if [[ -z "$upstream" ]]; then
        no_upstream_branches+=("$branch")
      else
        ahead=$(git -C "$repo" rev-list --count "${upstream}..${branch}" 2>/dev/null || echo 0)
        if (( ahead > 0 )); then
          unpushed_info+=("$branch ($ahead commits ahead of $upstream)")
        fi
      fi
    done < <(git -C "$repo" branch --format='%(refname:short)' 2>/dev/null)

    (( ${#no_upstream_branches[@]} > 0 )) && tags+=("no-upstream:${#no_upstream_branches[@]}")
    (( ${#unpushed_info[@]} > 0 ))        && tags+=("unpushed:${#unpushed_info[@]}")
  fi

  while IFS= read -r -d '' f; do
    base=$(basename "$f")
    case "$base" in
      *.example|*.sample|*.dist|*.template) continue ;;
    esac
    env_files+=("${f#$repo/}")
  done < <(find "$repo" -not -path "*/.git/*" \( -name ".env" -o -name ".env.*" \) -print0 2>/dev/null)

  (( ${#env_files[@]} > 0 )) && tags+=("env-files")

  (( ${#tags[@]} == 0 )) && continue
  any_flagged=1

  rel="${repo#$path_abs/}"
  [[ "$rel" == "$repo" ]] && rel="."

  if (( verbose )); then
    printf '%s\n' "$rel"
    if (( ${#detail_modified[@]} > 0 )); then
      printf '  Modified:    %s\n' "$(truncate_list "${detail_modified[@]}")"
    fi
    if (( ${#detail_staged[@]} > 0 )); then
      printf '  Staged:      %s\n' "$(truncate_list "${detail_staged[@]}")"
    fi
    if (( ${#detail_untracked[@]} > 0 )); then
      printf '  Untracked:   %s\n' "$(truncate_list "${detail_untracked[@]}")"
    fi
    for info in "${unpushed_info[@]+"${unpushed_info[@]}"}"; do
      printf '  Unpushed:    %s\n' "$info"
    done
    if (( ${#no_upstream_branches[@]} > 0 )); then
      printf '  No upstream: %s\n' "$(truncate_list "${no_upstream_branches[@]}")"
      any_no_upstream=1
    fi
    for tag in "${tags[@]}"; do
      case "$tag" in
        no-remote) printf '  No remote configured\n' ;;
      esac
    done
    if (( ${#env_files[@]} > 0 )); then
      printf '  Env files:   %s\n' "$(truncate_list "${env_files[@]}")"
    fi
  else
    printf '%s' "$rel"
    for tag in "${tags[@]}"; do
      printf ' [%s%s%s]' "$CLR_TAG" "$tag" "$CLR_RESET"
    done
    printf '\n'
    (( ${#no_upstream_branches[@]} > 0 )) && any_no_upstream=1
  fi
done

# --- Unreadable directory report ---
#
# Appended after the per-repo loop so permission failures are visible in
# the same listing. Each unreadable entry contributes to exit 1.

for u in "${unreadable[@]:-}"; do
  [[ -z "$u" ]] && continue
  any_flagged=1
  rel="${u#$path_abs/}"
  [[ "$rel" == "$u" ]] && rel="$u"
  if (( verbose )); then
    printf '%s\n  Unreadable (permission denied)\n' "$rel"
  else
    printf '%s [%s%s%s]\n' "$rel" "$CLR_TAG" "unreadable" "$CLR_RESET"
  fi
done

(( any_no_upstream )) && printf '\nTip: connect the current branch to its remote counterpart:\n  git branch --set-upstream-to=origin/$(git branch --show-current)\n'

(( any_flagged )) && exit 1
exit 0
